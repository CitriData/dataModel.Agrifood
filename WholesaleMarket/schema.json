        "type": {
          "type": "string",
          "description": "Property. NGSI Entity Type. It has to be WholesaleMarket.",
          "enum": [
            "WholesaleMarket"
          ]
        },
        "startPrice": {
          "type": "number",
          "description": "Property. Model:'https://schema.org/Number'. Precio Inicio Periodo"
        },
        "endPrice": {
          "type": "number",
          "description": "Property. Model:'https://schema.org/Number'. Precio Fin Periodo"
        },
        "market": {
