        },
        "year": {
          "type": "number",
          "description": "Property. Model:'https://schema.org/Number'. Año"
        },
        "week": {
          "type": "number",
          "description": "Property. Model:'https://schema.org/Number'. Semana"
        },
        "dataOwner": {
          "type": "string",
          "description": "Property. Model:'https://schema.org/Text'. Propietario del dato"
        },
        "dataProvider": {
          "type": "string",
          "description": "Property. Model:'https://schema.org/Text'. Proveedor del dato"
        }
      }
    }
  ],
  "required": [
